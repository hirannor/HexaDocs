<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="001-create-documents" author="hirannor">
        <createTable tableName="HEX_DOCUMENTS">

            <column name="ID" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="DOCUMENT_ID" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="KNOWLEDGE_BASE_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="FILE_REFERENCE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="CONTENT_TYPE" type="VARCHAR(128)"/>

            <column name="CREATED_AT" type="TIMESTAMP"/>
            <column name="UPDATED_AT" type="TIMESTAMP"/>

        </createTable>

        <createIndex tableName="HEX_DOCUMENTS"
                     indexName="IDX_DOC_KB">
            <column name="KNOWLEDGE_BASE_ID"/>
        </createIndex>

        <createSequence
                sequenceName="documents_seq"
                startValue="1"
                incrementBy="5"/>

    </changeSet>
</databaseChangeLog>