<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="003-create-ingestion-jobs" author="hirannor">
        <createTable tableName="HEX_INGESTION_JOBS">

            <column name="ID" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="JOB_ID" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="DOCUMENT_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="KNOWLEDGE_BASE_ID" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>

            <column name="ERROR" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>

            <column name="CREATED_AT" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="HEX_INGESTION_JOBS"
                     indexName="IDX_JOB_DOC">
            <column name="DOCUMENT_ID"/>
        </createIndex>

        <createSequence
                sequenceName="ingestion_job_seq"
                startValue="1"
                incrementBy="5"/>

    </changeSet>
</databaseChangeLog>